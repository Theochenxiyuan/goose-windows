<Window
    x:Class="GooseLauncher.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Goose Launcher Settings">

  <Grid Padding="24" RowSpacing="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Spacing="4">
      <TextBlock x:Name="TitleTextBlock" Text="Goose Launcher Settings" FontSize="28" FontWeight="SemiBold" />
      <TextBlock
          x:Name="SubtitleTextBlock"
          Text="Only Windows integration is configured here. Models, credentials, and extensions remain in Goose."
          TextWrapping="Wrap"
          Opacity="0.68" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <InfoBar
            x:Name="BoundaryInfoBar"
            IsOpen="True"
            IsClosable="False"
            Severity="Informational" />

        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="CliPathTextBox" Header="Goose CLI path" />
          <Button x:Name="BrowseCliButton" Grid.Column="1" VerticalAlignment="Bottom" Content="Browse…" Click="BrowseCli_Click" />
          <Button x:Name="AutoCliButton" Grid.Column="2" VerticalAlignment="Bottom" Content="Auto" Click="AutoCli_Click" />
        </Grid>

        <Grid ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBox x:Name="DesktopPathTextBox" Header="Goose Desktop path" />
          <Button x:Name="BrowseDesktopButton" Grid.Column="1" VerticalAlignment="Bottom" Content="Browse…" Click="BrowseDesktop_Click" />
          <Button x:Name="AutoDesktopButton" Grid.Column="2" VerticalAlignment="Bottom" Content="Auto" Click="AutoDesktop_Click" />
        </Grid>

        <ComboBox
            x:Name="RunTargetComboBox"
            Header="Open tasks in"
            HorizontalAlignment="Stretch">
          <ComboBoxItem x:Name="DesktopTargetItem" Content="Goose Desktop" Tag="Desktop" />
          <ComboBoxItem x:Name="TerminalTargetItem" Content="Terminal" Tag="Terminal" />
        </ComboBox>

        <ToggleSwitch
            x:Name="StartWithWindowsToggle"
            Header="Start with Windows"
            OffContent="Off"
            OnContent="On" />

        <InfoBar x:Name="ResultInfoBar" IsOpen="False" IsClosable="True" />
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2" ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button x:Name="CloseButton" Grid.Column="1" Content="Close" Click="Close_Click" />
      <Button x:Name="SaveButton" Grid.Column="2" Content="Save" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
    </Grid>
  </Grid>
</Window>
