<Window x:Class="GooseLauncher.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Goose Launcher" Width="600" Height="520" MinWidth="440" MinHeight="380"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" ShowInTaskbar="False" Topmost="True"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
        PreviewKeyDown="Window_PreviewKeyDown">
  <Border BorderThickness="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Padding="18">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <DockPanel x:Name="DragRegion" LastChildFill="True" MouseLeftButtonDown="DragRegion_MouseLeftButtonDown">
        <Button x:Name="CloseButton" DockPanel.Dock="Right" Content="×" Width="32" MinWidth="32" Padding="2" Click="Close_Click" />
        <StackPanel>
          <TextBlock x:Name="TitleText" Text="Goose Launcher" FontSize="20" FontWeight="SemiBold" />
          <TextBlock x:Name="FolderText" Margin="0,5,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </StackPanel>
      </DockPanel>

      <Border Grid.Row="1" Margin="0,12,0,0" Padding="10,7" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <TextBlock x:Name="FilesText" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
      </Border>

      <Grid Grid.Row="2" Margin="0,12,0,0">
        <TextBox x:Name="PromptBox" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 AutomationProperties.Name="Task prompt" SpellCheck.IsEnabled="True"
                 TextCompositionManager.PreviewTextInputStart="PromptBox_TextInputStart"
                 TextCompositionManager.PreviewTextInputUpdate="PromptBox_TextInputUpdate"
                 TextCompositionManager.TextInput="PromptBox_TextInput" />
        <Grid x:Name="RunPanel" Visibility="Collapsed">
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <TextBlock x:Name="StatusText" FontWeight="SemiBold" Text="Starting Goose…" />
          <TextBox x:Name="OutputText" Grid.Row="1" Margin="0,8,0,0" IsReadOnly="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" AutomationProperties.Name="Goose run summary" />
        </Grid>
      </Grid>

      <Border x:Name="PermissionPanel" Grid.Row="3" Margin="0,12,0,0" Padding="12" BorderThickness="1"
              BorderBrush="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Visibility="Collapsed">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <TextBlock x:Name="PermissionText" TextWrapping="Wrap" FontWeight="SemiBold" />
          <StackPanel Grid.Row="1" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="DenyButton" Content="Deny" Margin="0,0,8,0" Click="Deny_Click" />
            <Button x:Name="AllowButton" Content="Allow" Click="Allow_Click" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="4" Margin="0,14,0,0">
        <TextBlock x:Name="HintText" VerticalAlignment="Center" Opacity="0.65" Text="Enter to run · Shift/Ctrl+Enter for newline · Esc to close" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="ConfigureGooseButton" Content="Configure in Goose" Margin="0,0,8,0" Visibility="Collapsed" Click="ConfigureGoose_Click" />
          <Button x:Name="OpenGooseButton" Content="Open Goose" Margin="0,0,8,0" Visibility="Collapsed" Click="OpenGoose_Click" />
          <Button x:Name="CancelButton" Content="Cancel" Margin="0,0,8,0" Visibility="Collapsed" Click="CancelRun_Click" />
          <Button x:Name="RunButton" Content="Run" Background="{StaticResource AccentBrush}" Foreground="White" Click="Run_Click" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
