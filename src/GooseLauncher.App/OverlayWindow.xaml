<Window
    x:Class="GooseLauncher.App.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Ask Goose">

  <Border
      Padding="18"
      CornerRadius="14"
      BorderThickness="1"
      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
      Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
    <Grid RowSpacing="12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Spacing="7">
        <Grid
            x:Name="MoveRegion"
            Background="Transparent"
            PointerPressed="MoveRegion_PointerPressed"
            PointerMoved="MoveRegion_PointerMoved"
            PointerReleased="MoveRegion_PointerReleased"
            PointerCanceled="MoveRegion_PointerCanceled"
            PointerCaptureLost="MoveRegion_PointerCaptureLost">
          <TextBlock
              x:Name="HeaderTitleText"
              IsHitTestVisible="False"
              Text="Run Goose here"
              FontSize="18"
              FontWeight="SemiBold" />
        </Grid>

        <Border
            Padding="10,7"
            CornerRadius="7"
            Background="{ThemeResource ControlFillColorDefaultBrush}">
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon Glyph="&#xE8B7;" FontSize="14" VerticalAlignment="Center" />
            <TextBlock
                x:Name="FolderPathTextBlock"
                Grid.Column="1"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis"
                ToolTipService.ToolTip="{Binding Text, ElementName=FolderPathTextBlock}" />
          </Grid>
        </Border>

        <Border
            x:Name="FilesPanel"
            Padding="10,7"
            CornerRadius="7"
            Background="{ThemeResource ControlFillColorDefaultBrush}"
            Visibility="Collapsed">
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon Glyph="&#xE723;" FontSize="14" VerticalAlignment="Center" />
            <TextBlock
                x:Name="FilesTextBlock"
                Grid.Column="1"
                VerticalAlignment="Center"
                TextTrimming="CharacterEllipsis"
                ToolTipService.ToolTip="{Binding Text, ElementName=FilesTextBlock}" />
          </Grid>
        </Border>
      </StackPanel>

      <Grid Grid.Row="1" RowSpacing="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="PromptTextBox"
            MinHeight="82"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            ScrollViewer.VerticalScrollMode="Auto"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            AutomationProperties.Name="Task prompt"
            PlaceholderText="Tell Goose what to do…"
            TextChanged="PromptTextBox_TextChanged"
            PreviewKeyDown="PromptTextBox_PreviewKeyDown"
            KeyDown="PromptTextBox_KeyDown" />
        <InfoBar
            x:Name="ErrorInfoBar"
            Grid.Row="1"
            IsOpen="False"
            IsClosable="False"
            Severity="Error" />
      </Grid>

      <Border
          x:Name="PermissionPanel"
          Grid.Row="2"
          Padding="12"
          CornerRadius="7"
          BorderThickness="1"
          BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
          Visibility="Collapsed">
        <Grid RowSpacing="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock x:Name="PermissionTextBlock" TextWrapping="Wrap" FontWeight="SemiBold" />
          <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
            <Button x:Name="DenyButton" Content="Deny" Click="Deny_Click" />
            <Button x:Name="AllowButton" Content="Allow" Click="Allow_Click" Style="{StaticResource AccentButtonStyle}" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="3" RowSpacing="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            x:Name="HintTextBlock"
            Opacity="0.62"
            Text="Enter to run · Shift/Ctrl+Enter for newline · Esc to close" />
        <Grid Grid.Row="1" ColumnSpacing="8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
          </Grid.ColumnDefinitions>
          <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
            <Button x:Name="CloseButton" Content="Close" Click="Close_Click" />
            <Button x:Name="OpenSettingsButton" Content="Settings" Visibility="Collapsed" Click="OpenSettings_Click" />
            <Button x:Name="OpenTargetButton" Content="Open Goose Desktop" Click="OpenTarget_Click" />
            <Button x:Name="RunButton" Content="Run" Click="Run_Click" Style="{StaticResource AccentButtonStyle}" />
          </StackPanel>
          <Grid Grid.Column="1" Width="24" Height="24" VerticalAlignment="Bottom">
            <TextBlock
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontSize="14"
                Opacity="0.5"
                Text="◢"
                IsHitTestVisible="False" />
            <primitives:Thumb
                x:Name="ResizeThumb"
                AutomationProperties.Name="Resize window"
                DragDelta="ResizeThumb_DragDelta" />
          </Grid>
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
