{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goose.ai/schemas/windows/desktop-activation-v2.json",
  "title": "Goose Desktop activation protocol v2",
  "type": "object",
  "required": ["protocolVersion", "requestId", "action", "authToken", "files", "bringToFront"],
  "properties": {
    "protocolVersion": { "const": 2 },
    "requestId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$" },
    "action": { "enum": ["ping", "capabilities", "run", "open"] },
    "authToken": { "type": "string", "minLength": 1, "maxLength": 128 },
    "cwd": { "type": "string", "maxLength": 32767 },
    "prompt": { "type": "string", "maxLength": 65536 },
    "files": { "type": "array", "maxItems": 8, "items": { "type": "string", "minLength": 1, "maxLength": 32767 } },
    "bringToFront": { "type": "boolean" },
    "sessionSelection": {
      "type": "object",
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string", "minLength": 1, "maxLength": 256 },
        "model": { "type": "string", "minLength": 1, "maxLength": 512 },
        "thinkingEffort": { "enum": ["off", "low", "medium", "high", "max"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "run" } } },
      "then": { "required": ["cwd", "prompt"] },
      "else": {
        "properties": { "files": { "maxItems": 0 } },
        "not": { "required": ["sessionSelection"] }
      }
    }
  ]
}
